ZONIX_DATABASE_URL=postgresql://zonix:zonix@127.0.0.1:55432/zonix
ZONIX_ENV=development
ZONIX_BOOTSTRAP_ADMIN_USERNAME=admin
ZONIX_BOOTSTRAP_ADMIN_PASSWORD=local-dev-admin-change-me
ZONIX_BOOTSTRAP_USERS_JSON=[{"username":"alice","password":"editor","role":"editor","authSource":"local"},{"username":"bob","password":"viewer","role":"viewer","authSource":"local"},{"username":"oidc.admin","role":"admin","authSource":"oidc:corp-oidc"},{"username":"oidc.editor","role":"editor","authSource":"oidc:corp-oidc"},{"username":"oidc.viewer","role":"viewer","authSource":"oidc:corp-oidc"}]
ZONIX_BOOTSTRAP_ZONE_GRANTS_JSON=[{"username":"alice","zoneName":"example.com","actions":["write"]},{"username":"bob","zoneName":"internal.example","actions":["read"]}]
ZONIX_SESSION_SECRET_KEY=local-dev-session-secret-change-me-32-bytes
ZONIX_SESSION_TTL_SECONDS=43200
ZONIX_OIDC_BOOTSTRAP_NAME=corp-oidc
ZONIX_OIDC_BOOTSTRAP_ISSUER=http://mock-oidc:9000
ZONIX_OIDC_BOOTSTRAP_CLIENT_ID=zonix-ui
ZONIX_OIDC_BOOTSTRAP_CLIENT_SECRET=super-secret
ZONIX_OIDC_BOOTSTRAP_SCOPES=openid,profile,email
ZONIX_OIDC_BOOTSTRAP_CLAIMS_MAPPING_RULES={"usernameClaim":"preferred_username","rolesClaim":"groups","adminGroups":["dns-admins"],"zoneEditorPattern":"zone-{zone}-editors","zoneViewerPattern":"zone-{zone}-viewers"}
ZONIX_POWERDNS_BACKEND_NAME=powerdns-local
ZONIX_POWERDNS_API_URL=http://localhost:8081
ZONIX_POWERDNS_API_KEY=zonix-dev-powerdns-key
ZONIX_POWERDNS_SERVER_ID=localhost
ZONIX_POWERDNS_TIMEOUT_SECONDS=5
VITE_API_BASE_URL=http://localhost:8000
