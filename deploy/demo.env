ZONIX_HOST_POSTGRES_PORT=55432
ZONIX_HOST_POWERDNS_API_PORT=8081
ZONIX_HOST_POWERDNS_DNS_PORT=5300
ZONIX_HOST_KEYCLOAK_PORT=9011
ZONIX_HOST_OIDC_GATEWAY_PORT=9010
ZONIX_HOST_BACKEND_PORT=8000
ZONIX_HOST_FRONTEND_PORT=5173
ZONIX_DATABASE_URL=postgresql://zonix:zonix@postgres:5432/zonix
ZONIX_DATABASE_CONNECT_TIMEOUT_SECONDS=2
ZONIX_ENV=development
ZONIX_BOOTSTRAP_ADMIN_ENABLED=true
ZONIX_BOOTSTRAP_ADMIN_USERNAME=admin
ZONIX_BOOTSTRAP_ADMIN_PASSWORD=local-dev-admin-change-me
ZONIX_BOOTSTRAP_USERS_JSON=[{"username":"alice","password":"editor","role":"editor","authSource":"local"},{"username":"bob","password":"viewer","role":"viewer","authSource":"local"},{"username":"oidc.admin","role":"admin","authSource":"oidc:corp-oidc"},{"username":"oidc.editor","role":"editor","authSource":"oidc:corp-oidc"},{"username":"oidc.viewer","role":"viewer","authSource":"oidc:corp-oidc"}]
ZONIX_BOOTSTRAP_ZONE_GRANTS_JSON=[{"username":"alice","zoneName":"example.com","actions":["write"]},{"username":"bob","zoneName":"internal.example","actions":["read"]}]
ZONIX_SESSION_SECRET_KEY=local-dev-session-secret-change-me-32-bytes
ZONIX_SESSION_COOKIE_SAMESITE=lax
ZONIX_SESSION_COOKIE_SECURE=false
ZONIX_SESSION_TTL_SECONDS=43200
ZONIX_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,backend
ZONIX_SECURITY_HEADERS_ENABLED=true
ZONIX_SECURITY_HEADERS_PERMISSIONS_POLICY=accelerometer=(), autoplay=(), camera=(), display-capture=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), publickey-credentials-get=(), usb=()
ZONIX_REQUEST_MAX_BODY_BYTES=65536
ZONIX_LOGIN_RATE_LIMIT_ATTEMPTS=5
ZONIX_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
ZONIX_AUTH_OIDC_SELF_SIGNUP_ENABLED=false
ZONIX_OIDC_BOOTSTRAP_NAME=corp-oidc
ZONIX_OIDC_BOOTSTRAP_ISSUER=http://oidc-gateway:9000/realms/zonix
ZONIX_OIDC_BOOTSTRAP_CLIENT_ID=zonix-ui
ZONIX_OIDC_BOOTSTRAP_CLIENT_SECRET=super-secret
ZONIX_OIDC_BOOTSTRAP_SCOPES=openid,groups
ZONIX_OIDC_BOOTSTRAP_CLAIMS_MAPPING_RULES={"usernameClaim":"preferred_username","rolesClaim":"groups","adminGroups":["dns-admins"],"zoneEditorPattern":"zone-{zone}-editors","zoneViewerPattern":"zone-{zone}-viewers"}
ZONIX_POWERDNS_BACKEND_NAME=powerdns-local
ZONIX_POWERDNS_BACKEND_ENABLED=true
ZONIX_POWERDNS_API_URL=http://powerdns:8081
ZONIX_POWERDNS_API_KEY=zonix-dev-powerdns-key
ZONIX_POWERDNS_SERVER_ID=localhost
ZONIX_POWERDNS_TIMEOUT_SECONDS=5
ZONIX_BIND_BACKEND_ENABLED=false
ZONIX_BIND_BACKEND_NAME=bind-lab
ZONIX_BIND_SERVER_HOST=bind
ZONIX_BIND_SERVER_PORT=53
ZONIX_BIND_TIMEOUT_SECONDS=5
ZONIX_BIND_AXFR_ENABLED=true
ZONIX_BIND_TSIG_KEY_NAME=
ZONIX_BIND_TSIG_SECRET=
ZONIX_BIND_TSIG_ALGORITHM=hmac-sha256
ZONIX_BIND_ZONE_NAMES=
ZONIX_BIND_SNAPSHOT_FILE_MAP={}
ZONIX_DEV_PROXY_TARGET=http://backend:8000
